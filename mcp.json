{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "context7-mcp-server"]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp"]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "sequential-thinking-mcp"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp"]
    },
    "skills": {
      "command": "npx",
      "args": ["-y", "@anthropic-ai/skills"],
      "skills": [
        "@anthropic-ai/skills:nextjs",
        "@anthropic-ai/skills:react",
        "@anthropic-ai/skills:typescript",
        "@anthropic-ai/skills:tailwindcss",
        "@anthropic-ai/skills:testing",
        "@anthropic-ai/skills:accessibility"
      ]
    }
  },
  "specKit": {
    "enabled": true,
    "aiAgent": "qwen",
    "scriptType": "ps",
    "version": "0.2.0",
    "slashCommands": [
      "/speckit.constitution",
      "/speckit.specify",
      "/speckit.clarify",
      "/speckit.plan",
      "/speckit.tasks",
      "/speckit.implement",
      "/speckit.analyze",
      "/speckit.checklist"
    ],
    "artifacts": {
      "constitution": ".specify/memory/constitution.md",
      "specs": ".specify/specs/",
      "templates": ".specify/templates/",
      "scripts": ".specify/scripts/powershell/"
    }
  }
}
